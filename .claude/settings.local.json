  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(echo $CLAUDE_TOOL_INPUT_COMMAND); if echo \"$CMD\" | grep -qE 'git commit|git push'; then echo '❌ 禁止自动执行 git commit / git push 操作。代码修改完成后，请人工核验变更内容后再手动提交。'; exit 1; fi; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo $CLAUDE_TOOL_INPUT_FILE_PATH); if echo \"$FILE\" | grep -q '^old/'; then echo '❌ 禁止修改 old/ 目录文件'; exit 1; fi; exit 0"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo $CLAUDE_TOOL_INPUT_FILE_PATH); ruff format \"$FILE\" && ruff check \"$FILE\" --fix"
          }
        ]
      }
    ]
  }
