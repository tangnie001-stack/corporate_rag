{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "启动 Gradio 应用 (WSL)",
            "type": "debugpy",
            "request": "launch",
            "module": "src.app",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "调试当前文件 (WSL)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        }
    ]
}